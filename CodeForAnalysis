## Compare two methods in the SAME repeated nested CV framework
## Method 1: metabolite-only index + covariates in downstream lm
## Method 2: covariates + metabolites jointly in glmnet (not good model, I did not use it)
## =========================================================
# Run following code after "helper" functions above

suppressPackageStartupMessages({
  library(dplyr)
  library(glmnet)
})


# ---------- helper: prepare covariates using TRAIN only ----------
prep_covars_train_test <- function(tr, te, covars){
  if (length(covars) == 0){
    return(list(
      Xtr = matrix(nrow = nrow(tr), ncol = 0),
      Xte = matrix(nrow = nrow(te), ncol = 0),
      colnames = character(0)
    ))
  }
  
  tr2 <- tr[, covars, drop = FALSE]
  te2 <- te[, covars, drop = FALSE]
  
  # identify numeric vs categorical
  is_num <- vapply(tr2, function(x) {
    is.numeric(x) || is.integer(x)
  }, logical(1))
  
  num_covars <- names(is_num)[is_num]
  cat_covars <- names(is_num)[!is_num]
  
  # numeric: median impute + z-score using TRAIN only
  Xtr_num <- NULL
  Xte_num <- NULL
  if (length(num_covars) > 0){
    Xtr_num0 <- as.data.frame(tr2[, num_covars, drop = FALSE])
    Xte_num0 <- as.data.frame(te2[, num_covars, drop = FALSE])
    
    for (v in num_covars){
      Xtr_num0[[v]] <- numify(Xtr_num0[[v]])
      Xte_num0[[v]] <- numify(Xte_num0[[v]])
      
      med <- median(Xtr_num0[[v]], na.rm = TRUE)
      if (is.na(med)) med <- 0
      
      Xtr_num0[[v]][is.na(Xtr_num0[[v]])] <- med
      Xte_num0[[v]][is.na(Xte_num0[[v]])] <- med
      
      mu <- mean(Xtr_num0[[v]], na.rm = TRUE)
      sdv <- sd(Xtr_num0[[v]], na.rm = TRUE)
      if (is.na(sdv) || sdv == 0) sdv <- 1
      
      Xtr_num0[[v]] <- (Xtr_num0[[v]] - mu) / sdv
      Xte_num0[[v]] <- (Xte_num0[[v]] - mu) / sdv
    }
    
    Xtr_num <- as.matrix(Xtr_num0)
    Xte_num <- as.matrix(Xte_num0)
  } else {
    Xtr_num <- matrix(nrow = nrow(tr), ncol = 0)
    Xte_num <- matrix(nrow = nrow(te), ncol = 0)
  }
  
  # categorical: train levels only, one-hot encoding
  Xtr_cat <- NULL
  Xte_cat <- NULL
  if (length(cat_covars) > 0){
    tr_cat <- tr2[, cat_covars, drop = FALSE]
    te_cat <- te2[, cat_covars, drop = FALSE]
    
    for (v in cat_covars){
      tr_cat[[v]] <- factor(tr_cat[[v]])
      te_cat[[v]] <- factor(te_cat[[v]], levels = levels(tr_cat[[v]]))
    }
    
    mm_tr <- model.matrix(~ . , data = tr_cat)
    mm_te <- model.matrix(~ . , data = te_cat)
    
    # remove intercept
    if ("(Intercept)" %in% colnames(mm_tr)) {
      mm_tr <- mm_tr[, setdiff(colnames(mm_tr), "(Intercept)"), drop = FALSE]
    }
    if ("(Intercept)" %in% colnames(mm_te)) {
      mm_te <- mm_te[, setdiff(colnames(mm_te), "(Intercept)"), drop = FALSE]
    }
    
    # align columns
    all_cols <- union(colnames(mm_tr), colnames(mm_te))
    add_missing_cols <- function(M, all_cols){
      miss <- setdiff(all_cols, colnames(M))
      if (length(miss) > 0){
        M2 <- matrix(0, nrow = nrow(M), ncol = length(miss))
        colnames(M2) <- miss
        M <- cbind(M, M2)
      }
      M[, all_cols, drop = FALSE]
    }
    
    Xtr_cat <- add_missing_cols(mm_tr, all_cols)
    Xte_cat <- add_missing_cols(mm_te, all_cols)
    
    # NA in test due to unseen level -> 0
    Xte_cat[is.na(Xte_cat)] <- 0
  } else {
    Xtr_cat <- matrix(nrow = nrow(tr), ncol = 0)
    Xte_cat <- matrix(nrow = nrow(te), ncol = 0)
  }
  
  Xtr <- cbind(Xtr_num, Xtr_cat)
  Xte <- cbind(Xte_num, Xte_cat)
  
  if (is.null(dim(Xtr))) Xtr <- matrix(Xtr, nrow = nrow(tr))
  if (is.null(dim(Xte))) Xte <- matrix(Xte, nrow = nrow(te))
  
  list(
    Xtr = Xtr,
    Xte = Xte,
    colnames = colnames(Xtr)
  )
}


# ---------- helper: metric summary ----------
summarize_perf <- function(df, method_name){
  data.frame(
    method = method_name,
    n_folds = nrow(df),
    median_R2   = median(df$r2, na.rm = TRUE),
    mean_R2     = mean(df$r2, na.rm = TRUE),
    median_RMSE = median(df$rmse, na.rm = TRUE),
    mean_RMSE   = mean(df$rmse, na.rm = TRUE),
    median_MAE  = median(df$mae, na.rm = TRUE),
    mean_MAE    = mean(df$mae, na.rm = TRUE)
  )
}


# ---------- main comparison function ----------
compare_two_methods_nested_cv <- function(
    df,
    outcome_col,
    covars,
    metab_cols_all,
    alpha = 0.2,
    K = 5,
    R = 30,
    screen_method = c("topk", "p"),
    p_thresh = 0.05,
    topk = 10,
    lambda_choice = c("min", "1se"),
    seed = 1
){
  screen_method <- match.arg(screen_method)
  lambda_choice <- match.arg(lambda_choice)
  
  set.seed(seed)
  
  dat0 <- df %>%
    select(all_of(c(outcome_col, covars, metab_cols_all))) %>%
    mutate(across(all_of(metab_cols_all), numify))
  
  dat0[[outcome_col]] <- numify(dat0[[outcome_col]])
  dat0 <- dat0 %>% filter(!is.na(.data[[outcome_col]]))
  
  n <- nrow(dat0)
  if (n < K * 2) stop("Too few samples for chosen K.")
  
  make_folds <- function(n, K) sample(rep(1:K, length.out = n))
  
  perf_m1 <- list()
  perf_m2 <- list()
  
  for (r in seq_len(R)){
    fold_id <- make_folds(n, K)
    
    for (k in seq_len(K)){
      idx_te <- which(fold_id == k)
      idx_tr <- setdiff(seq_len(n), idx_te)
      
      tr0 <- dat0[idx_tr, , drop = FALSE]
      te0 <- dat0[idx_te, , drop = FALSE]
      
      ## -----------------------------------------
      ## same TRAIN-only screening for both methods
      ## -----------------------------------------
      mets_sel <- screen_mets_train(
        tr_df = tr0,
        outcome_col = outcome_col,
        covars = covars,
        metab_cols = metab_cols_all,
        method = screen_method,
        p_thresh = p_thresh,
        topk = topk,
        min_n = 25
      )
      
      if (length(mets_sel) == 0) next
      
      ytr <- numify(tr0[[outcome_col]])
      yte <- numify(te0[[outcome_col]])
      
      ## =========================================
      ## Method 1: metabolite-only index + covars
      ## =========================================
      pp_met <- prep_x_train_test(tr0, te0, mets_sel)
      Xtr_met <- pp_met$Xtr
      Xte_met <- pp_met$Xte
      
      cvfit_m1 <- cv.glmnet(
        x = Xtr_met,
        y = ytr,
        family = "gaussian",
        alpha = alpha,
        standardize = FALSE
      )
      lam1 <- if (lambda_choice == "1se") cvfit_m1$lambda.1se else cvfit_m1$lambda.min
      
      b1 <- as.matrix(coef(cvfit_m1, s = lam1))
      beta_mets <- as.numeric(b1[mets_sel, 1])
      names(beta_mets) <- mets_sel
      
      if (all(beta_mets == 0)) {
        w1 <- rep(0, length(beta_mets))
        names(w1) <- names(beta_mets)
      } else {
        w1 <- beta_mets / sum(abs(beta_mets))
      }
      
      idx_tr_score <- as.numeric(Xtr_met %*% w1)
      idx_te_score <- as.numeric(Xte_met %*% w1)
      
      mu_i <- mean(idx_tr_score, na.rm = TRUE)
      sd_i <- sd(idx_tr_score, na.rm = TRUE)
      if (is.na(sd_i) || sd_i == 0) sd_i <- 1
      
      tr_eval <- tr0
      te_eval <- te0
      tr_eval$index_z <- (idx_tr_score - mu_i) / sd_i
      te_eval$index_z <- (idx_te_score - mu_i) / sd_i
      
      covars_use <- covars
      for (cv in covars_use){
        if (is.character(tr_eval[[cv]]) || is.factor(tr_eval[[cv]])){
          tr_eval[[cv]] <- factor(tr_eval[[cv]])
          te_eval[[cv]] <- factor(te_eval[[cv]], levels = levels(tr_eval[[cv]]))
          if (nlevels(tr_eval[[cv]]) < 2){
            covars_use <- setdiff(covars_use, cv)
          }
        }
      }
      
      fml1 <- reformulate(c("index_z", covars_use), response = outcome_col)
      fit1 <- lm(fml1, data = tr_eval)
      pred1 <- predict(fit1, newdata = te_eval)
      
      rmse1 <- sqrt(mean((yte - pred1)^2, na.rm = TRUE))
      mae1  <- mean(abs(yte - pred1), na.rm = TRUE)
      r21   <- 1 - sum((yte - pred1)^2, na.rm = TRUE) /
        sum((yte - mean(yte, na.rm = TRUE))^2, na.rm = TRUE)
      
      perf_m1[[length(perf_m1) + 1]] <- data.frame(
        rep = r,
        fold = k,
        method = "Method1_index_plus_covars",
        n_selected = length(mets_sel),
        rmse = rmse1,
        mae = mae1,
        r2 = r21
      )
      
      ## =========================================
      ## Method 2: covars + metabolites jointly in glmnet
      ## =========================================
      pp_cov <- prep_covars_train_test(tr0, te0, covars)
      Xtr_cov <- pp_cov$Xtr
      Xte_cov <- pp_cov$Xte
      
      Xtr_joint <- cbind(Xtr_met, Xtr_cov)
      Xte_joint <- cbind(Xte_met, Xte_cov)
      
      cvfit_m2 <- cv.glmnet(
        x = Xtr_joint,
        y = ytr,
        family = "gaussian",
        alpha = alpha,
        standardize = FALSE
      )
      lam2 <- if (lambda_choice == "1se") cvfit_m2$lambda.1se else cvfit_m2$lambda.min
      
      pred2 <- as.numeric(
        predict(cvfit_m2, newx = Xte_joint, s = lam2)
      )
      
      rmse2 <- sqrt(mean((yte - pred2)^2, na.rm = TRUE))
      mae2  <- mean(abs(yte - pred2), na.rm = TRUE)
      r22   <- 1 - sum((yte - pred2)^2, na.rm = TRUE) /
        sum((yte - mean(yte, na.rm = TRUE))^2, na.rm = TRUE)
      
      perf_m2[[length(perf_m2) + 1]] <- data.frame(
        rep = r,
        fold = k,
        method = "Method2_joint_glmnet",
        n_selected = length(mets_sel),
        rmse = rmse2,
        mae = mae2,
        r2 = r22
      )
    }
  }
  
  perf_m1_df <- bind_rows(perf_m1)
  perf_m2_df <- bind_rows(perf_m2)
  perf_all   <- bind_rows(perf_m1_df, perf_m2_df)
  
  summary_tab <- bind_rows(
    summarize_perf(perf_m1_df, "Method1_index_plus_covars"),
    summarize_perf(perf_m2_df, "Method2_joint_glmnet")
  )
  
  # decide winner
  winner_r2   <- summary_tab$method[which.max(summary_tab$median_R2)]
  winner_rmse <- summary_tab$method[which.min(summary_tab$median_RMSE)]
  winner_mae  <- summary_tab$method[which.min(summary_tab$median_MAE)]
  
  cat("\n================ MODEL COMPARISON ================\n")
  print(summary_tab, row.names = FALSE)
  cat("--------------------------------------------------\n")
  cat("Higher median R2 winner   :", winner_r2, "\n")
  cat("Lower median RMSE winner  :", winner_rmse, "\n")
  cat("Lower median MAE winner   :", winner_mae, "\n")
  
  if (winner_r2 == winner_rmse && winner_rmse == winner_mae) {
    cat("Overall better model      :", winner_r2, "\n")
  } else {
    cat("Overall better model      : mixed results across metrics\n")
  }
  cat("==================================================\n\n")
  
  list(
    perf_all = perf_all,
    perf_method1 = perf_m1_df,
    perf_method2 = perf_m2_df,
    summary = summary_tab
  )
}


