run_spearman_one <- function(df, metab_col, outcome_col = "SCV_Percentchange_PDFF"){
  tmp <- df[, c(metab_col, outcome_col), drop = FALSE]
  colnames(tmp) <- c("metab", "outcome")
  
  tmp$metab   <- numify(tmp$metab)
  tmp$outcome <- numify(tmp$outcome)
  tmp <- tmp[complete.cases(tmp), , drop = FALSE]
  
  n_use <- nrow(tmp)
  if(n_use < 8){
    return(data.frame(
      metabolite = metab_col,
      n = n_use,
      rho = NA_real_,
      p = NA_real_
    ))
  }
  
  ct <- suppressWarnings(
    cor.test(tmp$metab, tmp$outcome, method = "spearman", exact = FALSE)
  )
  
  data.frame(
    metabolite = metab_col,
    n = n_use,
    rho = unname(ct$estimate),
    p = ct$p.value
  )
}

run_spearman_panel <- function(df, metab_cols, outcome_col = "SCV_Percentchange_PDFF"){
  bind_rows(lapply(metab_cols, function(m){
    run_spearman_one(df, m, outcome_col = outcome_col)
  })) %>%
    mutate(
      logp = -log10(p),
      group = case_when(
        !is.na(rho) & rho >  0.2 & p < 0.05 ~ "up",
        !is.na(rho) & rho < -0.2 & p < 0.05 ~ "down",
        TRUE ~ "normal"
      ),
      group = factor(group, levels = c("down", "normal", "up"))
    ) %>%
    arrange(rho)
}

