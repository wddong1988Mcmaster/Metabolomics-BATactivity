# Step 3 — Interaction testing（cleaner）
# 3A) metabolite × Sex（adults only）
# Model:
# SCV_Percentchange_PDFF ~ metab_z * Sex + Age + BodyFatPercent
run_pdff_int_sex <- function(df, metab_col, min_n = 30){
  
  dfm <- df %>%
    filter(AdultChild=="Adult") %>%
    select(SCV_Percentchange_PDFF, Age, Sex, BodyFatPercent, all_of(metab_col)) %>%
    mutate(
      SCV_Percentchange_PDFF = as.numeric(SCV_Percentchange_PDFF),
      Age = as.numeric(Age),
      BodyFatPercent = as.numeric(BodyFatPercent),
      Sex = factor(Sex),
      metab_z = as.numeric(scale(as.numeric(.data[[metab_col]])))
    ) %>%
    select(-all_of(metab_col)) %>%
    na.omit()
  
  if (nrow(dfm) < min_n) return(NULL)
  
  fit <- lm(SCV_Percentchange_PDFF ~ metab_z*Sex + Age + BodyFatPercent, data = dfm)
  coefs <- summary(fit)$coefficients
  int_term <- grep("^metab_z:Sex", rownames(coefs), value = TRUE)
  
  data.frame(
    metabolite = metab_col,
    beta_int_sex = if(length(int_term)==1) unname(coefs[int_term,"Estimate"]) else NA_real_,
    p_int_sex    = if(length(int_term)==1) unname(coefs[int_term,"Pr(>|t|)"]) else NA_real_
  )
}

# 3B) metabolite × AdultChild（adults vs children）
# Model:
# SCV_Percentchange_PDFF ~ metab_z * AdultChild + Age + Sex + BodyFatPercent
run_pdff_int_agegroup <- function(df, metab_col, min_n = 30){
  
  dfm <- df %>%
    select(SCV_Percentchange_PDFF, Age, Sex, BodyFatPercent, AdultChild, all_of(metab_col)) %>%
    mutate(
      SCV_Percentchange_PDFF = as.numeric(SCV_Percentchange_PDFF),
      Age = as.numeric(Age),
      BodyFatPercent = as.numeric(BodyFatPercent),
      Sex = factor(Sex),
      AdultChild = factor(AdultChild, levels = c("Adult","Child")),
      metab_z = as.numeric(scale(as.numeric(.data[[metab_col]])))
    ) %>%
    select(-all_of(metab_col)) %>%
    na.omit()
  
  if (nrow(dfm) < min_n) return(NULL)
  
  fit <- lm(SCV_Percentchange_PDFF ~ metab_z*AdultChild + Age + Sex + BodyFatPercent, data = dfm)
  coefs <- summary(fit)$coefficients
  int_term <- "metab_z:AdultChildChild"
  
  data.frame(
    metabolite = metab_col,
    beta_int_agegroup = if(int_term %in% rownames(coefs)) unname(coefs[int_term,"Estimate"]) else NA_real_,
    p_int_agegroup    = if(int_term %in% rownames(coefs)) unname(coefs[int_term,"Pr(>|t|)"]) else NA_real_
  )
}

