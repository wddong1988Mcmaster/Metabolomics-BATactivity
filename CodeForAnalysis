# ---------- helpers ----------
numify <- function(x){
  if (is.factor(x)) x <- as.character(x)
  if (is.character(x)) {
    x <- trimws(x)
    x[x %in% c("", "NA", "NaN", "null", "NULL")] <- NA
  }
  suppressWarnings(as.numeric(x))
}

# train-only median impute + zscore
prep_x_train_test <- function(tr, te, mets){
  Xtr <- as.matrix(tr[, mets, drop=FALSE])
  Xte <- as.matrix(te[, mets, drop=FALSE])
  
  # impute by train medians
  med <- apply(Xtr, 2, function(x){
    if(all(is.na(x))) NA_real_ else median(x, na.rm=TRUE)
  })
  for (j in seq_along(mets)){
    if (is.na(med[j])) {  # all-NA column: set directly to 0 (equivalent to zero contribution after z-scoring)
      Xtr[, j] <- 0
      Xte[, j] <- 0
    } else {
      Xtr[is.na(Xtr[, j]), j] <- med[j]
      Xte[is.na(Xte[, j]), j] <- med[j]
    }
  }
  
  # zscore by train mean/sd
  mu <- colMeans(Xtr)
  sdv <- apply(Xtr, 2, sd)
  sdv[is.na(sdv) | sdv == 0] <- 1
  
  Xtr_z <- sweep(sweep(Xtr, 2, mu, "-"), 2, sdv, "/")
  Xte_z <- sweep(sweep(Xte, 2, mu, "-"), 2, sdv, "/")
  
  list(Xtr = Xtr_z, Xte = Xte_z, mu = mu, sd = sdv, med = med)
}

# --- univariate screening in TRAIN only (adjusting covars) ---
screen_mets_train <- function(tr_df, outcome_col, covars, metab_cols,
                              method = c("p", "topk"),
                              p_thresh = 0.05,
                              topk = 10,
                              min_n = 25){
  method <- match.arg(method)
  
  keep_cols <- unique(c(outcome_col, covars, metab_cols))
  tr <- tr_df[, keep_cols, drop=FALSE]
  
  tr[[outcome_col]] <- numify(tr[[outcome_col]])
  
  # helper to backtick any column name safely
  bt <- function(x) paste0("`", x, "`")
  
  get_p <- function(m){
    dfm <- tr[, c(outcome_col, covars, m), drop=FALSE]
    dfm[[m]] <- numify(dfm[[m]])
    dfm <- dfm[complete.cases(dfm), , drop=FALSE]
    if (nrow(dfm) < min_n) return(NA_real_)
    
    # build formula as string to safely handle spaces/hyphens
    rhs <- c(bt(m), bt(covars))
    fml_str <- paste(bt(outcome_col), "~", paste(rhs, collapse = " + "))
    fit <- try(lm(as.formula(fml_str), data = dfm), silent = TRUE)
    if (inherits(fit, "try-error")) return(NA_real_)
    
    coefs <- summary(fit)$coefficients
    # rowname will be the raw column name (not backticked) in most cases
    if (!m %in% rownames(coefs)) {
      # fallback: try matching backticked name
      if (!bt(m) %in% rownames(coefs)) return(NA_real_)
      return(unname(coefs[bt(m), "Pr(>|t|)"]))
    }
    unname(coefs[m, "Pr(>|t|)"])
  }
  
  pvals <- vapply(metab_cols, get_p, numeric(1))
  out <- data.frame(metabolite = metab_cols, p = pvals) %>%
    filter(!is.na(p)) %>%
    arrange(p)
  
  if (nrow(out) == 0) return(character(0))
  
  if (method == "p"){
    sel <- out %>% filter(p < p_thresh) %>% pull(metabolite)
    if (length(sel) < 3){
      sel <- head(out$metabolite, min(topk, nrow(out)))
    }
  } else {
    sel <- head(out$metabolite, min(topk, nrow(out)))
  }
  
  sel
}


# ---------- main nested CV with dynamic screening ----------
nested_cv_enet_dynamic_screen <- function(
    df,
    outcome_col,
    covars,
    metab_cols_all,          # all candidate metabolites you allow screening over
    alpha = 0.2,             # your ENET_ALPHA
    K = 5,
    R = 50,
    screen_method = c("topk","p"),
    p_thresh = 0.05,
    topk = 10,
    lambda_choice = c("1se","min"),
    seed = 1
){
  screen_method <- match.arg(screen_method)
  lambda_choice <- match.arg(lambda_choice)
  
  set.seed(seed)
  
  # keep and clean minimal columns
  dat0 <- df %>%
    select(all_of(c(outcome_col, covars, metab_cols_all))) %>%
    mutate(across(all_of(metab_cols_all), numify))
  
  dat0[[outcome_col]] <- numify(dat0[[outcome_col]])
  dat0 <- dat0 %>% filter(!is.na(.data[[outcome_col]]))
  
  n <- nrow(dat0)
  if (n < K*2) stop("Too few samples for chosen K.")
  
  make_folds <- function(n, K) sample(rep(1:K, length.out = n))
  
  perf_list <- list()
  coef_list <- list()
  screen_list <- list()
  
  for (r in seq_len(R)){
    fold_id <- make_folds(n, K)
    
    for (k in 1:K){
      idx_te <- which(fold_id == k)
      idx_tr <- setdiff(seq_len(n), idx_te)
      
      tr0 <- dat0[idx_tr, , drop=FALSE]
      te0 <- dat0[idx_te, , drop=FALSE]
      
      # ---- dynamic screening within TRAIN only ----
      mets_sel <- screen_mets_train(
        tr_df = tr0,
        outcome_col = outcome_col,
        covars = covars,
        metab_cols = metab_cols_all,
        method = screen_method,
        p_thresh = p_thresh,
        topk = topk,
        min_n = 25
      )
      
      screen_list[[length(screen_list)+1]] <- data.frame(rep=r, fold=k, n_selected=length(mets_sel))
      
      # if nothing selected, skip fold
      if (length(mets_sel) == 0) next
      
      # ---- build X/y for glmnet on TRAIN ----
      tr <- tr0
      te <- te0
      
      # prepare standardized X using TRAIN-only stats
      pp <- prep_x_train_test(tr, te, mets_sel)
      Xtr <- pp$Xtr
      Xte <- pp$Xte
      ytr <- numify(tr[[outcome_col]])
      yte <- numify(te[[outcome_col]])
      
      # inner CV choose lambda on TRAIN only
      cvfit <- cv.glmnet(
        x = Xtr, y = ytr,
        family = "gaussian",
        alpha = alpha,
        standardize = FALSE
      )
      lam <- if (lambda_choice == "1se") cvfit$lambda.1se else cvfit$lambda.min
      
      b <- as.matrix(coef(cvfit, s = lam))  # includes intercept
      b_mets <- as.numeric(b[mets_sel, 1])
      names(b_mets) <- mets_sel
      n_enet_nonzero <- sum(b_mets != 0)
      
      
      # L1 normalize metabolite weights
      if (all(b_mets == 0)){
        w <- rep(0, length(mets_sel)); names(w) <- mets_sel
      } else {
        w <- b_mets / sum(abs(b_mets))
      }
      
      # compute index scores
      idx_tr_score <- as.numeric(Xtr %*% w)
      idx_te_score <- as.numeric(Xte %*% w)
      
      # ---- build train/test eval frames with index_z (standardize using TRAIN only) ----
      mu_i <- mean(idx_tr_score); sd_i <- sd(idx_tr_score); if (sd_i == 0) sd_i <- 1
      
      tr_eval <- tr
      te_eval <- te
      tr_eval$index_z <- (idx_tr_score - mu_i) / sd_i
      te_eval$index_z <- (idx_te_score - mu_i) / sd_i
      
      # ---- FIX: drop covariates that have <2 levels in TRAIN ----
      covars_use <- covars
      
      for (cv in covars_use){
        if (is.character(tr_eval[[cv]]) || is.factor(tr_eval[[cv]])){
          tr_eval[[cv]] <- factor(tr_eval[[cv]])
          te_eval[[cv]] <- factor(te_eval[[cv]], levels = levels(tr_eval[[cv]]))
          if (nlevels(tr_eval[[cv]]) < 2){
            covars_use <- setdiff(covars_use, cv)
          }
        }
      }
      
      # build formula with remaining covariates
      fml <- reformulate(c("index_z", covars_use), response = outcome_col)
      
      # fit on TRAIN, predict on TEST (true out-of-sample)
      fit_train <- lm(fml, data = tr_eval)
      pred <- predict(fit_train, newdata = te_eval)
      r_s <- suppressWarnings(cor(te_eval[[outcome_col]], pred, method="spearman", use="complete.obs"))
      mae <- mean(abs(te_eval[[outcome_col]] - pred), na.rm=TRUE)
      
      rmse <- sqrt(mean((te_eval[[outcome_col]] - pred)^2, na.rm=TRUE))
      r2   <- 1 - sum((te_eval[[outcome_col]] - pred)^2, na.rm=TRUE) /
        sum((te_eval[[outcome_col]] - mean(te_eval[[outcome_col]], na.rm=TRUE))^2, na.rm=TRUE)
      
      # also record how many covars were used
      n_covars_used <- length(covars_use)
      
      perf_list[[length(perf_list)+1]] <- data.frame(
        rep=r, fold=k,
        n_train=nrow(tr), n_test=nrow(te),
        n_screened=length(metab_cols_all),
        n_selected=length(mets_sel),   # always 20 (screening)
        n_enet_nonzero=n_enet_nonzero,        # ✅ true number of non-zero ENet features
        n_covars_used=n_covars_used,          # ✅ how many covariates were actually used in this fold
        rmse=rmse, r2=r2,
        mae=mae, spearman=r_s
      )
      
      # store coefficients for stability (on screened set)
      coef_list[[length(coef_list)+1]] <- data.frame(
        rep=r, fold=k,
        metabolite=mets_sel,
        beta=b_mets,
        weight_L1=w
      )
    }
  }
  
  perf <- bind_rows(perf_list)
  coefs <- bind_rows(coef_list)
  screen_info <- bind_rows(screen_list)
  
  # stability summary (on metabolites that ever appeared)
  perf <- bind_rows(perf_list)
  coefs <- bind_rows(coef_list)
  screen_info <- bind_rows(screen_list)
  
  # Fix the denominator as the total number of folds (K*R), to avoid next/skip affecting frequency interpretation
  n_folds_total <- K * R
  
  stability <- coefs %>%
    mutate(
      selected = (beta != 0)
    ) %>%
    group_by(metabolite) %>%
    summarise(
      screen_freq = n() / n_folds_total,                       # frequency of entering the topk (counted across all folds)
      select_given_screened = mean(selected, na.rm = TRUE),    # conditional probability: probability of being retained by ENet after entering the topk
      select_overall = sum(selected, na.rm = TRUE) / n_folds_total, # overall retention frequency, counted across all folds
      sign_consistency = {
        bsel <- beta[selected]
        if (length(bsel) == 0) NA_real_ else max(mean(bsel > 0), mean(bsel < 0))
      },
      beta_median = median(beta[selected], na.rm = TRUE),
      beta_IQR    = IQR(beta[selected], na.rm = TRUE),
      .groups = "drop"
    ) %>%
    arrange(desc(select_overall), desc(screen_freq))
  
  list(perf = perf, coefs = coefs, stability = stability, screen_info = screen_info)
  
  
}

# ---------- permutation wrapper ----------
perm_test_nested_dynamic <- function(
    df, outcome_col, covars, metab_cols_all,
    alpha = 0.2, K = 5, R = 30,
    screen_method = "topk", p_thresh = 0.05, topk = 10, # or topk = 15
    lambda_choice = "1se",
    B = 200,
    seed = 1
){
  set.seed(seed)
  
  obs <- nested_cv_enet_dynamic_screen(
    df=df, outcome_col=outcome_col, covars=covars, metab_cols_all=metab_cols_all,
    alpha=alpha, K=K, R=R,
    screen_method=screen_method, p_thresh=p_thresh, topk=topk,
    lambda_choice=lambda_choice, seed=seed
  )
  obs_r2 <- median(obs$perf$r2, na.rm=TRUE)
  
  perm_r2 <- numeric(B)
  for (b in 1:B){
    dfp <- df
    dfp[[outcome_col]] <- sample(dfp[[outcome_col]])
    tmp <- nested_cv_enet_dynamic_screen(
      df=dfp, outcome_col=outcome_col, covars=covars, metab_cols_all=metab_cols_all,
      alpha=alpha, K=K, R=R,
      screen_method=screen_method, p_thresh=p_thresh, topk=topk,
      lambda_choice=lambda_choice, seed=seed + b
    )
    perm_r2[b] <- median(tmp$perf$r2, na.rm=TRUE)
  }
  
  p_emp <- (sum(perm_r2 >= obs_r2) + 1) / (B + 1)
  
  list(
    observed = obs,
    observed_median_r2 = obs_r2,
    perm_median_r2 = perm_r2,
    p_empirical = p_emp
  )
}





