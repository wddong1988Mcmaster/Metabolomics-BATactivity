# Step 2 — Stratified Spearman（supportive analysis: only look at direction）
# Stratification (according to your workflow):
# Adult + male
# Adult + female
# Child（sex-stratification is optional here; if needed, it can also be added）
run_spearman_rho <- function(df, metab_col){
  if (nrow(df) < 8) return(NA_real_)
  suppressWarnings(
    cor(df[[metab_col]],
        df$SCV_Percentchange_PDFF,
        method = "spearman",
        use = "complete.obs")
  )
}

spearman_tbl <- bind_rows(lapply(metabolite_cols, function(m){
  data.frame(
    metabolite = m,
    rho_male_adult   = run_spearman_rho(PDFF %>% filter(AdultChild=="Adult", Sex=="male"), m),
    rho_female_adult = run_spearman_rho(PDFF %>% filter(AdultChild=="Adult", Sex=="female"), m),
    rho_child        = run_spearman_rho(PDFF %>% filter(AdultChild=="Child"), m)
  )
}))

pdff_step2 <- pdff_step1 %>%
  left_join(spearman_tbl, by = "metabolite")

