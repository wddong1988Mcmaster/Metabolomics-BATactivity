run_pdff_step1 <- function(df, metab_col, min_n = 25){
  
  dfm <- df %>%
    select(
      SCV_Percentchange_PDFF,
      Age, Sex, BodyFatPercent, AdultChild,
      all_of(metab_col)
    ) %>%
    mutate(
      SCV_Percentchange_PDFF = as.numeric(SCV_Percentchange_PDFF),
      Age = as.numeric(Age),
      BodyFatPercent = as.numeric(BodyFatPercent),
      Sex = factor(Sex),                       # here it is "male"/"female" :contentReference[oaicite:3]{index=3}
      AdultChild = factor(AdultChild, levels = c("Adult","Child")),
      metab_z = as.numeric(scale(as.numeric(.data[[metab_col]])))
    ) %>%
    select(-all_of(metab_col)) %>%
    na.omit()
  
  if (nrow(dfm) < min_n) return(NULL)
  
  fit <- lm(
    SCV_Percentchange_PDFF ~ metab_z + Age + Sex + BodyFatPercent + AdultChild,
    data = dfm
  )
  
  coefs <- summary(fit)$coefficients
  
  data.frame(
    metabolite = metab_col,
    n_used = nrow(dfm),
    beta = unname(coefs["metab_z","Estimate"]),
    se   = unname(coefs["metab_z","Std. Error"]),
    p    = unname(coefs["metab_z","Pr(>|t|)"])
  ) %>%
    mutate(ci_lb = beta - 1.96*se,
           ci_ub = beta + 1.96*se)
}

pdff_step1 <- bind_rows(lapply(metabolite_cols, run_pdff_step1, df = PDFF)) %>%
  mutate(FDR = p.adjust(p, method = "BH")) %>%
  arrange(FDR)

