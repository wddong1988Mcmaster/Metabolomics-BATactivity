extract_model_info <- function(fit, index_name, model_name){
  sm <- summary(fit)
  coef_tab <- as.data.frame(sm$coefficients)
  
  # Extract the index row
  idx_row <- coef_tab[index_name, ]
  
  data.frame(
    Model = model_name,
    Index = index_name,
    
    Beta = idx_row["Estimate"],
    SE   = idx_row["Std. Error"],
    t    = idx_row["t value"],
    P    = idx_row["Pr(>|t|)"],
    
    R2       = sm$r.squared,
    Adj_R2   = sm$adj.r.squared,
    Residual_SE = sm$sigma,
    
    stringsAsFactors = FALSE
  )
}

## ---- Extract the two models ----
