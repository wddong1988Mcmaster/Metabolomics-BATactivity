BASE_FONT <- 15   # <<< change this one line to scale all text

theme_pub <- function(base_size = BASE_FONT){
  theme_classic(base_size = base_size) +
    theme(
      plot.title   = element_text(size = base_size + 1, face = "bold"),
      axis.title   = element_text(size = base_size),
      axis.text    = element_text(size = base_size),
      legend.title = element_text(size = base_size),
      legend.text  = element_text(size = base_size),
      strip.text   = element_text(size = base_size, face = "bold"),
      plot.caption = element_text(size = base_size - 1)
    )
}

save_both <- function(plot, filename_base, out_dir,
                      width = 6, height = 4, units = "in",
                      dpi = 300, bg = "white"){
  dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
  
  # TIFF (LZW compressed)
  ggsave(
    filename = file.path(out_dir, paste0(filename_base, ".tiff")),
    plot = plot, width = width, height = height, units = units,
    dpi = dpi, device = "tiff", compression = "lzw", bg = bg
  )
  
  # SVG (vector)
  ggsave(
    filename = file.path(out_dir, paste0(filename_base, ".svg")),
    plot = plot, width = width, height = height, units = units,
    device = "svg", bg = bg
  )
}

median_iqr_label <- function(x){
