plot_spearman_volcano <- function(res_df,
                                  title_txt = "Spearman",
                                  xlim_expand = 0.08,
                                  label_top_n = NULL){
  
  plot_df <- res_df %>%
    filter(!is.na(rho), !is.na(p), is.finite(logp))
  
  # Count numbers
  n_up     <- sum(plot_df$group == "up", na.rm = TRUE)
  n_down   <- sum(plot_df$group == "down", na.rm = TRUE)
  n_normal <- sum(plot_df$group == "normal", na.rm = TRUE)
  
  sub_txt <- paste0(
    "Up (rho>0.2): ", n_up,
    "   Down (rho<-0.2): ", n_down,
    "   p<0.05"
  )
  
  # Label only significant points
  lab_df <- plot_df %>%
    filter(group != "normal")
  
  # If you only want to label the most significant few, set label_top_n
  if(!is.null(label_top_n)){
    lab_df <- lab_df %>%
      arrange(p) %>%
      slice_head(n = label_top_n)
  }
  
  x_max <- max(abs(plot_df$rho), na.rm = TRUE) + xlim_expand
  
  ggplot(plot_df, aes(x = rho, y = logp, color = group)) +
    geom_vline(xintercept = c(-0.2, 0.2), linetype = "dashed", color = "black", linewidth = 0.5) +
    geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "black", linewidth = 0.5) +
    
    geom_point(size = 2.2, alpha = 0.9) +
    
    ggrepel::geom_text_repel(
      data = lab_df,
      aes(label = metabolite),
      size = BASE_SIZE / 3.5,
      box.padding = 0.25,
      point.padding = 0.15,
      segment.size = 0.25,
      max.overlaps = Inf,
      show.legend = FALSE
    ) +
    
    scale_color_manual(
      values = c(
        "down"   = "#2C7FB8",
        "normal" = "#B3B3B3",
        "up"     = "#D7191C"
      )
    ) +
    
    coord_cartesian(xlim = c(-x_max, x_max)) +
    
    labs(
      title = title_txt,
      subtitle = sub_txt,
      x = "Spearman rho (metabolites & SCV_PDFF%)",
      y = "-log10(p-value)",
      color = "Group"
    ) +
    
    theme_classic(base_size = BASE_SIZE) +
    theme(
      text = element_text(size = BASE_SIZE),
      plot.title = element_text(size = BASE_SIZE, face = "bold"),
      plot.subtitle = element_text(size = BASE_SIZE - 1),
      axis.title.x = element_text(size = BASE_SIZE),
      axis.title.y = element_text(size = BASE_SIZE),
      axis.text.x = element_text(size = BASE_SIZE),
      axis.text.y = element_text(size = BASE_SIZE),
      legend.title = element_text(size = BASE_SIZE),
      legend.text = element_text(size = BASE_SIZE)
    )
}

