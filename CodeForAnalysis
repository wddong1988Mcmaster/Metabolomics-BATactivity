## After = 1, Before = 0
## =========================
df$y <- ifelse(df$ColdExposure == "After", 1, 0)

table(df$ColdExposure, df$y)

## =========================
## 3) ROC helper function
## direction is set automatically
## =========================
get_roc <- function(marker, outcome, marker_name){
  roc_obj <- roc(
    response = outcome,
    predictor = marker,
    quiet = TRUE,
    ci = TRUE
  )
  
  auc_val <- as.numeric(auc(roc_obj))
  ci_val  <- ci.auc(roc_obj)
  
  list(
    roc = roc_obj,
    auc = auc_val,
    ci_low = as.numeric(ci_val[1]),
    ci_high = as.numeric(ci_val[3]),
    name = marker_name
  )
}

## =========================
## 4) Run ROC for each marker
## =========================
roc_list <- list(
  get_roc(df$Zscore_Palmitoleic, df$y, "Zscore_Palmitoleic"),
  get_roc(df$Zscore_Hexanoyl,    df$y, "Zscore_Hexanoyl-L-carnitine"),
  get_roc(df$Palmitoleic,        df$y, "Palmitoleic acid"),
  get_roc(df$Hexanoyl,           df$y, "Hexanoyl-L-carnitine"),
  get_roc(df$Index_1se,          df$y, "Index_1se")
)

## =========================
## 5) AUC summary table
## =========================
auc_table <- bind_rows(lapply(roc_list, function(x){
  data.frame(
    Marker = x$name,
    AUC = round(x$auc, 3),
    CI95 = paste0("(", round(x$ci_low, 3), ", ", round(x$ci_high, 3), ")")
  )
}))

print(auc_table)

## =========================
## 6) Best cutoff / sensitivity / specificity
## =========================
best_cut_table <- bind_rows(lapply(roc_list, function(x){
  best <- coords(
    x$roc, "best",
    ret = c("threshold", "sensitivity", "specificity"),
    transpose = FALSE
  )
  data.frame(
    Marker = x$name,
    Threshold = best["threshold"],
    Sensitivity = best["sensitivity"],
    Specificity = best["specificity"]
  )
}))

print(best_cut_table)

## =========================
## 7) Build plotting dataframe for ggplot
## =========================
roc_df <- bind_rows(lapply(roc_list, function(x){
  data.frame(
    FPR = 1 - x$roc$specificities,
    TPR = x$roc$sensitivities,
    Marker = paste0(
      x$name, " (AUC=", sprintf("%.3f", x$auc), ")"
    )
  )
}))

## =========================
## 8) Plot ROC curves
## =========================
p_roc <- ggplot(roc_df, aes(x = FPR, y = TPR, color = Marker)) +
  geom_line(linewidth = 1.2) +
  geom_abline(intercept = 0, slope = 1, linetype = 2, color = "grey50") +
  coord_equal() +
  labs(
    x = "1 - Specificity",
    y = "Sensitivity",
    title = "ROC curves for discriminating Before vs After cold exposure"
  ) +
  theme_classic(base_size = 14) +
  theme(
    plot.title = element_text(size = 14),
    legend.title = element_blank(),
    legend.position = "right"
  )

print(p_roc)

