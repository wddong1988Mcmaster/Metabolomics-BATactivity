coef_nonzero <- function(cv, s = "lambda.min"){
  b <- coef(cv, s = s)
  tibble(feature = rownames(b), beta = as.numeric(b)) %>%
    filter(feature != "(Intercept)", beta != 0) %>%
    arrange(desc(abs(beta)))
}

score_from_coef <- function(X, coef_tbl){
  b <- coef_tbl$beta; names(b) <- coef_tbl$feature
  feats <- intersect(colnames(X), names(b))
  as.numeric(X[, feats, drop = FALSE] %*% b[feats])
}

