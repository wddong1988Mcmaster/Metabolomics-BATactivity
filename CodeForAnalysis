#In the case of union 60 (high collinearity + p≈n), alpha=0.5 + 1se can easily produce all zeros; ENET_ALPHA <- 0.2   # or 0.1

build_Xy_pdff_final2 <- function(df, outcome_col, covars, mets_df){
  stopifnot(nrow(df) == nrow(mets_df))
  
  # 1) outcome + keep rows (determine this first)
  y_all <- numify(df[[outcome_col]])
  keep  <- is.finite(y_all)
  
  df2   <- df[keep, , drop = FALSE]
  y     <- y_all[keep]
  mets2 <- mets_df[keep, , drop = FALSE]
  
  # 2) covariates clean + impute
  cov_df <- df2[, covars, drop = FALSE]
  for(cc in covars){
    v <- cov_df[[cc]]
    
    # character -> factor (trim)
    if(is.character(v)) v <- factor(trimws(v))
    
    # drop 1-level factors
    if(is.factor(v) && nlevels(v) < 2){
      cov_df[[cc]] <- NULL
      next
    }
    
    # numeric impute
    if(!is.factor(v)){
      v <- numify(v)
      if(anyNA(v)) v[is.na(v)] <- median(v, na.rm = TRUE)
      cov_df[[cc]] <- v
    } else {
      # factor: replace NA with "Missing"
      vv <- as.character(v)
      vv[is.na(vv) | vv==""] <- "Missing"
      cov_df[[cc]] <- factor(vv)
      if(nlevels(cov_df[[cc]]) < 2) cov_df[[cc]] <- NULL
    }
  }
  
  # 3) metabolites: drop all-NA/low-nonNA columns (CRITICAL for PDFF)
  mets2 <- as.data.frame(mets2, check.names = FALSE)
  nonNA <- colSums(!is.na(mets2))
  min_nonNA <- 10  # you can change this to 5/10/20; for PDFF n=92, 10 is quite reasonable
  mets2 <- mets2[, nonNA >= min_nonNA, drop = FALSE]
  
  # Force numeric conversion (to avoid odd data types)
  mets2 <- as.data.frame(lapply(mets2, numify), check.names = FALSE)
  
  # 4) build model matrix WITHOUT dropping rows
  mm_df <- data.frame(cov_df, mets2, check.names = FALSE)
  X <- model.matrix(~ . , data = mm_df, na.action = na.pass)[, -1, drop = FALSE]
  
  # 5) impute remaining NA in X
  X <- median_impute_matrix(X)
  
  list(X = X, y = y, keep = keep, kept_mets = colnames(mets2))
}


