zscore_df <- function(df, cols){
  X <- df[, cols, drop = FALSE]
  X <- as.data.frame(lapply(X, numify))
  mu <- sapply(X, function(v) mean(v, na.rm = TRUE))
  sdv <- sapply(X, function(v) sd(v, na.rm = TRUE))
  sdv[is.na(sdv) | sdv == 0] <- 1
  Xz <- sweep(X, 2, mu, "-")
  Xz <- sweep(Xz, 2, sdv, "/")
  Xz <- as.data.frame(Xz)
  colnames(Xz) <- cols
  Xz
}

median_impute_matrix <- function(X){
  X <- as.matrix(X)
  for(j in seq_len(ncol(X))){
    v <- X[, j]
    if(anyNA(v)){
      med <- median(v, na.rm = TRUE)
      v[is.na(v)] <- med
      X[, j] <- v
    }
  }
  X
}

